# Backend environment variables.
# Local dev: copy to `.env` and load it, or export these in your shell.
# Production: set these in the Render dashboard (never commit real values).

# --- Auth (set strong values in production) ---
JWT_SECRET=change-me-to-a-long-random-string
MM_PASSWORD=change-me-admin-password
MM01_PASSWORD=change-me-mm01-password

# --- AI provider key ---
# The backend uses this when the client sends no key (so the key never ships to
# the browser). Use your ROTATED OpenAI key.
OPENAI_API_KEY=sk-...your-rotated-openai-key...
# ANTHROPIC_API_KEY=sk-ant-...   # only if you switch the provider to Anthropic

# --- CORS ---
# Comma-separated allowed origins. In production, set to your Vercel URL.
# ALLOWED_ORIGINS=https://your-app.vercel.app
